# Python bytecode and cache
__pycache__/
*.py[cod]
*$py.class

# Virtual environments
.venv/
venv/
env/
ENV/

# Environment variables and local secrets
.env
.env.*
!.env.example

# Test, coverage, and tooling caches
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/

# Build artifacts
build/
dist/
*.egg-info/

# Editor and OS files
.vscode/
.idea/
.DS_Store
Thumbs.db

# Generated session data
storage/sessions/*
!storage/sessions/.gitkeep
storage/mock_sessions/*
